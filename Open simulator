# 1. Source the Global ROS 2 environment
source /opt/ros/foxy/setup.bash

# 2. Go to the simulator workspace
cd /sim_ws

# 3. Build the gym bridge (Only needed once, or if you change sim.yaml)
colcon build --packages-select f1tenth_gym_ros

# 4. Source the local install so ROS can find the launch files
source install/local_setup.bash

# 5. Launch the simulation environment
ros2 launch f1tenth_gym_ros gym_bridge_launch.py
